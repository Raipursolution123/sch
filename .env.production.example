# =============================================================================
# School ERP — Production server environment
# Copy to .env on the production server. Never commit the real .env file.
# =============================================================================

# --- Django (production) ---
SECRET_KEY=change-me-production-secret-key-min-64-chars
DEBUG=False
ALLOWED_HOSTS=your-school-domain.com,localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.production
TIME_ZONE=Asia/Kolkata
LOG_LEVEL=WARNING

# --- Database (MySQL) ---
DB_NAME=school_erp
DB_USER=school_erp
DB_PASSWORD=change-me-production-db-password
DB_HOST=mysql
DB_PORT=3306
MYSQL_ROOT_PASSWORD=change-me-production-root-password

# --- Redis ---
REDIS_PASSWORD=change-me-production-redis-password
REDIS_URL=redis://:change-me-production-redis-password@redis:6379/0
REDIS_PORT=6379

# --- Celery ---
CELERY_BROKER_URL=redis://:change-me-production-redis-password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change-me-production-redis-password@redis:6379/2

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Auth / Security ---
ALLOW_REGISTRATION=false

# --- CORS / CSRF (HTTPS production domain) ---
CORS_ALLOWED_ORIGINS=https://your-school-domain.com
CSRF_TRUSTED_ORIGINS=https://your-school-domain.com

# --- TLS / security (Nginx terminates HTTPS) ---
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# --- Sentry (optional — enable error monitoring) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0

# --- Docker / deploy ---
COMPOSE_PROJECT_NAME=school_prod
IMAGE_REGISTRY=ghcr.io/raipursolution123/sch
IMAGE_TAG=abc1234

HTTP_BIND_IP=0.0.0.0
HTTP_PUBLISH_PORT=80
HTTPS_BIND_IP=0.0.0.0
HTTPS_PUBLISH_PORT=443

PROD_DOMAIN=your-school-domain.com
CERTBOT_EMAIL=admin@your-school-domain.com

# --- Frontend build (used by CI when building images) ---
VITE_API_BASE_URL=/api/v1
VITE_APP_NAME=School ERP

# --- Backups (prod-backup.sh) ---
BACKUP_DIR=/var/backups/school-erp
BACKUP_RETENTION_DAYS=14
