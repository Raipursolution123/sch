# =============================================================================
# School ERP — Staging server environment (school.raipursolutions.com)
# Copy to .env on the staging server. Never commit the real .env file.
# =============================================================================

# --- Django (staging) ---
SECRET_KEY=change-me-staging-secret-key-min-50-chars
DEBUG=False
ALLOWED_HOSTS=school.raipursolutions.com,localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.staging
TIME_ZONE=Asia/Kolkata
LOG_LEVEL=INFO

# --- Database (MySQL) ---
DB_NAME=school_erp
DB_USER=school_erp
DB_PASSWORD=change-me-staging-db-password
DB_HOST=mysql
DB_PORT=3306
MYSQL_ROOT_PASSWORD=change-me-staging-root-password

# --- Redis ---
REDIS_PASSWORD=change-me-staging-redis-password
REDIS_URL=redis://:change-me-staging-redis-password@redis:6379/0
REDIS_PORT=6379

# --- Celery ---
CELERY_BROKER_URL=redis://:change-me-staging-redis-password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change-me-staging-redis-password@redis:6379/2

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=14

# --- CORS / CSRF (HTTPS staging domain) ---
CORS_ALLOWED_ORIGINS=https://school.raipursolutions.com
CSRF_TRUSTED_ORIGINS=https://school.raipursolutions.com

# --- TLS / security (Nginx terminates HTTPS) ---
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=86400

# --- Docker / deploy ---
COMPOSE_PROJECT_NAME=school_staging
IMAGE_REGISTRY=ghcr.io/raipursolution123/sch
# Set to the git commit SHA pushed by CI (e.g. abc1234). Do not use "latest" in production/staging.
IMAGE_TAG=abc1234

# Nginx host bindings (long syntax — do NOT use HTTP_PORT=127.0.0.1:8094 with compose)
HTTP_BIND_IP=0.0.0.0
HTTP_PUBLISH_PORT=80
HTTPS_BIND_IP=0.0.0.0
HTTPS_PUBLISH_PORT=443

# Shared VPS (host Apache owns 80/443) — use these instead:
# SHARED_VPS=true
# HTTP_BIND_IP=127.0.0.1
# HTTP_PUBLISH_PORT=8094
# HTTPS_BIND_IP=127.0.0.1
# HTTPS_PUBLISH_PORT=18443
# NGINX_STAGING_CONF=nginx.staging.http-only.conf
# SECURE_SSL_REDIRECT=False

STAGING_DOMAIN=school.raipursolutions.com
STAGING_URL=https://school.raipursolutions.com
CERTBOT_EMAIL=admin@raipursolutions.com

# --- Frontend build (used by CI when building images) ---
VITE_API_BASE_URL=/api/v1
VITE_APP_NAME=School ERP (Staging)
